# ============================================================
# QOON Platform — Environment Variables Template
# Copy this to .env and fill in real values
# NEVER commit .env to Git
# ============================================================

# Database
DB_HOST=145.223.33.118
DB_USER=qoon_Qoon
DB_PASS=CHANGE_THIS_PASSWORD
DB_NAME=qoon_Qoon

# Firebase FCM (Legacy + V1)
FCM_SERVER_KEY=CHANGE_THIS_FCM_KEY
FCM_PROJECT_ID=CHANGE_THIS_PROJECT_ID

# SMTP / Email
SMTP_HOST=mail.qoon.app
SMTP_USER=info@qoon.app
SMTP_PASS=CHANGE_THIS_SMTP_PASSWORD
SMTP_PORT=465

# Zendit eSIM API
ZENDIT_API_KEY=CHANGE_THIS_ZENDIT_KEY

# AliExpress API
ALI_APP_KEY=CHANGE_THIS
ALI_APP_SECRET=CHANGE_THIS

# NanoBanana VTO API
NANOBANANA_API_KEY=CHANGE_THIS

# App Settings
APP_ENV=production
APP_DOMAIN=https://qoon.app/userDriver/UserDriverApi/
ENABLE_REQUEST_LOGGING=false
